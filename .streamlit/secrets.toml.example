# Streamlit Cloud 배포 시 이 파일을 참고해서
# Streamlit Cloud > App settings > Secrets 에 아래 내용을 입력하세요.
# (이 .example 파일 자체는 커밋해도 안전합니다)

ANTHROPIC_API_KEY = "sk-ant-여기에입력"

# 네이버 로그인 후 브라우저 F12 → Application → Cookies → smartstore.naver.com
# 모든 쿠키를 한 줄로 복사해서 붙여넣기
NAVER_COOKIES = "NID_AUT=...; NID_SES=...; 나머지쿠키..."
